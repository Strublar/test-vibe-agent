									"key": "Date",
									"value": "Mon, 01 Jan 2024 12:00:00 GMT"
								},
								{
									"key": "Server",
									"value": "Kestrel"
								}
							],
							"cookie": [],
							"body": "pong"
						}
					]
				},
				{
					"name": "Ping - HTTPS",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response body is 'pong'\", function () {",
									"    pm.expect(pm.response.text()).to.eql('pong');",
									"});",
									"",
									"pm.test(\"Content-Type is text/plain\", function () {",
									"    pm.expect(pm.response.headers.get('Content-Type')).to.include('text/plain');",
									"});",
									"",
									"pm.test(\"Connection is secure (HTTPS)\", function () {",
									"    pm.expect(pm.request.url.protocol).to.eql('https');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "text/plain",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url_https}}/ping",
							"host": [
								"{{base_url_https}}"
							],
							"path": [
								"ping"
							]
						},
						"description": "Test de l'endpoint ping via HTTPS.\nDoit retourner 'pong' avec un status 200 sur une connexion sécurisée."
					},
					"response": []
				},
				{
					"name": "Ping - Case Insensitive",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response body is 'pong'\", function () {",
									"    pm.expect(pm.response.text()).to.eql('pong');",
									"});",
									"",
									"pm.test(\"Endpoint is case insensitive\", function () {",
									"    // Ce test valide que /PING fonctionne comme /ping",
									"    pm.expect(pm.response.status).to.eql('OK');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "text/plain",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/PING",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"PING"
							]
						},
						"description": "Test que l'endpoint ping n'est pas sensible à la casse.\nTest avec /PING qui doit retourner le même résultat que /ping."
					},
					"response": []
				}
			],
